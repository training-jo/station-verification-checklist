{
  "title": {
    "ar": "التحقق من إجراءات تحضير البطاطس المقلية",
    "en": "French Fries Procedure Verification"
  },
  "items": [
    {
      "text": {
        "ar": "النظافة وسلامة الغذاء",
        "en": "Food safety and hygiene"
      },
      "reasons": [
        { "ar": "لا يغسل يديه بشكل صحيح أو متكرر", "en": "Does not wash hands properly or frequently" },
        { "ar": "لا يدرك أهمية غسل اليدين كخطوة أساسية لسلامة الغذاء", "en": "Does not understand importance of handwashing for food safety" }
      ]
    },
    {
      "text": {
        "ar": "إعدادات القلاية",
        "en": "Fryer settings"
      },
      "reasons": [
        { "ar": "اختيار برنامج خاطئ (FR FRIES)", "en": "Wrong fryer program selected (FR FRIES)" },
        { "ar": "درجة الحرارة غير صحيحة (335°F)", "en": "Incorrect temperature (335°F)" },
        { "ar": "وقت الطهي غير صحيح (3 دقائق)", "en": "Incorrect cooking time (3 minutes)" }
      ]
    },
    {
      "text": {
        "ar": "تجهيز المعدات والمخزون",
        "en": "Equipment and stock check"
      },
      "reasons": [
        { "ar": "عدم توفر الأدوات (Skimmer / مناديل / بطاطس / زيت / أكياس)", "en": "Missing tools (skimmer, towels, fries, oil, bags)" },
        { "ar": "عدم فحص مستوى الزيت", "en": "Does not check oil level" },
        { "ar": "عدم تعبئة الزيت حتى الخط المطلوب", "en": "Does not fill oil to required level" }
      ]
    },
    {
      "text": {
        "ar": "تحميل السلال وجودة المنتج",
        "en": "Loading baskets and product quality"
      },
      "reasons": [
        { "ar": "عدم طهي البطاطس وهي مجمدة", "en": "Does not cook fries from frozen state" },
        { "ar": "التعامل مع البطاطس بشكل خشن", "en": "Handles fries roughly" },
        { "ar": "تلف المنتج بسبب سوء التعامل", "en": "Damages fries during handling" }
      ]
    },
    {
      "text": {
        "ar": "استخدام موزع البطاطس",
        "en": "Using frozen fries dispenser"
      },
      "reasons": [
        { "ar": "عدم تعبئة الخزان (Hopper)", "en": "Does not fill hopper" },
        { "ar": "عدم إرجاع البطاطس للفريزر", "en": "Does not return unused fries to freezer" },
        { "ar": "عدم إغلاق الغطاء", "en": "Does not close hopper lid" },
        { "ar": "إعدادات الكمية غير صحيحة", "en": "Incorrect volume settings" },
        { "ar": "عدم وضع السلال بشكل صحيح", "en": "Does not place baskets correctly" }
      ]
    },
    {
      "text": {
        "ar": "وضع البطاطس في الزيت",
        "en": "Placing in oil"
      },
      "reasons": [
        { "ar": "وضع السلة بشكل غير صحيح", "en": "Incorrect basket placement" },
        { "ar": "عدم تشغيل المؤقت", "en": "Does not start timer" },
        { "ar": "عدم غمر البطاطس بالكامل", "en": "Fries not fully submerged" },
        { "ar": "تعامل غير آمن يسبب تناثر الزيت", "en": "Unsafe handling causing oil splashing" }
      ]
    },
    {
      "text": {
        "ar": "هز السلة",
        "en": "Shake basket"
      },
      "reasons": [
        { "ar": "عدم هز السلة بعد 30 ثانية", "en": "Does not shake after 30 seconds" },
        { "ar": "عدم الهز 3–4 مرات", "en": "Does not shake 3–4 times" },
        { "ar": "التصاق البطاطس ببعضها", "en": "Fries stick together" }
      ]
    },
    {
      "text": {
        "ar": "الإزالة والتصفية",
        "en": "Remove and drain"
      },
      "reasons": [
        { "ar": "عدم الالتزام بالمؤقت", "en": "Does not follow timer" },
        { "ar": "عدم تصفية الزيت 5–10 ثواني", "en": "Does not drain for 5–10 seconds" },
        { "ar": "ترك السلة أكثر من 10 ثواني", "en": "Leaves basket too long" },
        { "ar": "البطاطس تصبح طرية", "en": "Fries become soggy" }
      ]
    },
    {
      "text": {
        "ar": "تفريغ البطاطس",
        "en": "Empty fries"
      },
      "reasons": [
        { "ar": "خلط القديم مع الجديد", "en": "Mixes old and new fries" },
        { "ar": "عدم تعليق السلة لتصفية الزيت", "en": "Does not hang basket to drain oil" },
        { "ar": "تساقط الزيت على الأرض", "en": "Oil dripping on floor" }
      ]
    },
    {
      "text": {
        "ar": "إضافة الملح",
        "en": "Salting"
      },
      "reasons": [
        { "ar": "عدم التمليح مباشرة", "en": "Does not salt immediately" },
        { "ar": "استخدام Accu Salt بشكل خاطئ", "en": "Incorrect use of Accu Salt" },
        { "ar": "عدم الحفاظ على ارتفاع 8 إنش", "en": "Incorrect height while salting" },
        { "ar": "عدم تطبيق حركة المظلة", "en": "Does not follow umbrella motion" },
        { "ar": "عدم خلط البطاطس بحركة الشلال", "en": "Does not mix fries properly" }
      ]
    },
    {
      "text": {
        "ar": "التعبئة",
        "en": "Packaging"
      },
      "reasons": [
        { "ar": "كمية غير صحيحة", "en": "Incorrect portioning" },
        { "ar": "عدم استخدام المغرفة بشكل صحيح", "en": "Incorrect scoop usage" },
        { "ar": "وضع المنتج في الصف الأول (منطقة باردة)", "en": "Uses first row (cold zone)" },
        { "ar": "تأخير في التقديم", "en": "Delay in serving" }
      ]
    },
    {
      "text": {
        "ar": "الجودة ومدة التقديم",
        "en": "Quality and holding time"
      },
      "reasons": [
        { "ar": "تقديم بطاطس بعد 7 دقائق", "en": "Serves fries older than 7 minutes" },
        { "ar": "عدم التخلص من المنتج المنتهي", "en": "Does not discard expired fries" },
        { "ar": "عدم تحقيق معايير الجودة", "en": "Does not meet quality standards" }
      ]
    },
    {
      "text": {
        "ar": "تنظيف الزيت والربحية",
        "en": "Oil cleaning and profitability"
      },
      "reasons": [
        { "ar": "عدم تنظيف الزيت من الشوائب", "en": "Does not skim oil" },
        { "ar": "عدم التنظيف كل 30 دقيقة", "en": "Does not skim every 30 minutes" },
        { "ar": "تراكم الشوائب", "en": "Oil contamination buildup" },
        { "ar": "تأثير على عمر الزيت", "en": "Reduces oil life" }
      ]
    },
    {
      "text": {
        "ar": "النظافة والسلامة",
        "en": "Cleanliness and safety"
      },
      "reasons": [
        { "ar": "عدم تنظيف المنطقة", "en": "Does not clean area" },
        { "ar": "خطر التلوث المتبادل", "en": "Risk of cross contamination" },
        { "ar": "عدم تغطية القلاية", "en": "Does not cover vats" }
      ]
    },
    {
      "text": {
        "ar": "العرض والتفاعل مع الضيف",
        "en": "Show & tell and guest interaction"
      },
      "reasons": [
        { "ar": "لا يستطيع شرح الخطوات", "en": "Cannot explain procedure" },
        { "ar": "لا يطبق الخطوات بشكل صحيح", "en": "Incorrect execution" },
        { "ar": "لا يتفاعل مع العميل", "en": "Does not engage with customer" },
        { "ar": "لا يطلب تقييم من العميل", "en": "Does not ask for feedback" }
      ]
    }
  ],
  "bands": [
    {
      "min": 0,
      "max": 6,
      "text": {
        "ar": "غير موثق - أعد التدريب",
        "en": "Not verified - retraining required"
      }
    },
    {
      "min": 7,
      "max": 11,
      "text": {
        "ar": "بحاجة إلى توجيه إضافي",
        "en": "Needs additional coaching"
      }
    },
    {
      "min": 12,
      "max": 14,
      "text": {
        "ar": "موثق للعمل بمفرده على المحطة",
        "en": "Verified to work independently"
      }
    }
  ]
}