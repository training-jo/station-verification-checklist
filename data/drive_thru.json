        { "ar": "لا يلتزم بوقت التجميع (≤120 ثانية)", "en": "Does not meet assembly time (≤120 sec)" },
        { "ar": "تجاوز الوقت الإجمالي (300 ثانية)", "en": "Total service time exceeds (300 sec)" }
