        { "ar": "ضعف في النظافة الشخصية", "en": "Poor personal hygiene" },
        { "ar": "الزي غير نظيف أو غير مرتب", "en": "Uniform not clean or not organized" },
        { "ar": "ارتداء إكسسوارات", "en": "Wearing accessories (rings, etc.)" },
        { "ar": "مظهر غير احترافي", "en": "Poor professional appearance" }
      ]
    },
    {
      "text": {
