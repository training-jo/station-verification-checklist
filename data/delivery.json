        { "ar": "لا يلتزم بوقت التحضير (5 دقائق)", "en": "Does not meet preparation time (5 min)" },
        { "ar": "تجاوز الوقت الكلي (7 دقائق)", "en": "Total time exceeds (7 min)" },
        { "ar": "ضعف إدارة الوقت", "en": "Poor time management" }
      ]
    },
    {
      "text": {
        "ar": "عملية إرسال الطلب (Dispatch)",
        "en": "Dispatch process"
      },
      "reasons": [
        { "ar": "لا يضغط “Ready” بشكل صحيح", "en": "Does not mark order as 'Ready' correctly" },
