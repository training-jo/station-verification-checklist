      "reasons": [
        { "ar": "تسليم الطلب دون التأكد من جاهزية المندوب", "en": "Hands order without checking rider readiness" },
        { "ar": "لا يتحقق من وجود حقيبة توصيل", "en": "Does not ensure rider has delivery bag" },
