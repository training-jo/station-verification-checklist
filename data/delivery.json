        { "ar": "كميات غير صحيحة", "en": "Wrong quantities" },
        { "ar": "عدم الالتزام بالتفاصيل", "en": "Does not follow order details" },
        { "ar": "ضعف الانتباه", "en": "Poor attention to details" }
      ]
    },
    {
