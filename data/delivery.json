        { "ar": "لا يغسل يديه قبل البدء", "en": "Does not wash hands before starting" },
        { "ar": "لا يغسل يديه بشكل منتظم (كل ساعة)", "en": "Does not wash hands regularly (every hour)" },
        { "ar": "ضعف في النظافة الشخصية", "en": "Poor personal hygiene" },
        { "ar": "الزي غير نظيف", "en": "Uniform not clean" },
        { "ar": "عدم الالتزام بمعايير النظافة", "en": "Ignores hygiene standards" }
      ]
    },
    {
      "text": {
