        { "ar": "تسليم طلب خاطئ", "en": "Hands wrong order" },
        { "ar": "لا يؤكد استلام الطلب (Pick-up)", "en": "Does not confirm pickup (Pick-up step)" },
        { "ar": "ضعف التواصل مع المندوب", "en": "Poor communication with rider" },
        { "ar": "عدم التحقق", "en": "Skips verification process" }
      ]
    },
    {
      "text": {
        "ar": "تنظيم ونظافة منطقة العمل",
        "en": "Workplace organization and cleanliness"
      },
      "reasons": [
        { "ar": "منطقة التوصيل غير منظمة", "en": "Delivery area not organized" },
        { "ar": "ترتيب الطلبات غير صحيح", "en": "Orders not arranged properly" },
        { "ar": "ضعف نظافة المحطة", "en": "Poor workstation cleanliness" },
        { "ar": "وضع الطعام في أماكن غير آمنة", "en": "Places food on unsafe surfaces" },
        { "ar": "سوء التعامل مع الأدوات", "en": "Poor handling of materials" }
      ]
    },
    {
      "text": {
        "ar": "سلامة الغذاء أثناء التوصيل",
        "en": "Safety and food protection"
      },
      "reasons": [
        { "ar": "وضع الطعام على الأرض", "en": "Places food on the floor" },
        { "ar": "عدم حماية الطعام أثناء التجهيز", "en": "Does not protect food during handling" },
        { "ar": "ضعف النظافة أثناء التغليف", "en": "Poor hygiene during packing" },
        { "ar": "تعامل غير آمن مع المنتجات الساخنة", "en": "Unsafe handling of hot items" },
        { "ar": "خطر التلوث", "en": "Risk of contamination" }
      ]
    },
    {
      "text": {
        "ar": "السلوك المهني",
        "en": "Professional behavior"
      },
      "reasons": [
        { "ar": "أسلوب غير احترافي مع المندوب", "en": "Poor attitude with riders" },
        { "ar": "ضعف في التواصل", "en": "Poor communication" },
        { "ar": "عدم الاحترام", "en": "Lack of respect" },
        { "ar": "عدم الالتزام بثقافة الخدمة", "en": "Does not follow service culture" },
        { "ar": "تعامل غير لائق", "en": "Not treating rider professionally" }
      ]
    }
