        { "ar": "يسمح بأكثر من طلب بشكل خاطئ", "en": "Allows multiple orders per rider incorrectly" },
        { "ar": "ضعف التحكم بالعملية", "en": "Poor control over delivery process" }
      ]
    },
    {
      "text": {
        "ar": "تسليم الطلب",
